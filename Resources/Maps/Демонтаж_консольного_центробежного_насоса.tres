script = ExtResource("2_u2v6e")
ScenarioName = "Демонтаж консольного центробежного насоса"
Description = "Учебно-производственный сценарий полной разборки центробежного насоса. Процесс включает: демонтаж задней крышки и извлечение подшипникового узла из спирального корпуса (улитки). Вам предстоит снять стяжные имбусовые винты, извлечь вал с рабочим колесом (турбиной). Строго соблюдайте технику безопасности при работе с фланцевыми соединениями."
